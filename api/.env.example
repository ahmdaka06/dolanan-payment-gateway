# ==============================================
# App
# ==============================================
APP_PORT=3000
APP_PREFIX=api/v1
NODE_ENV=development

# ==============================================
# Database (PostgreSQL)
# ==============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=dolanan
DB_PASSWORD=dolanan_secret
DB_DATABASE=dolanan_payment_gateway

# ==============================================
# JWT
# ==============================================
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ==============================================
# Tripay
# ==============================================
TRIPAY_API_KEY=your_tripay_api_key
TRIPAY_PRIVATE_KEY=your_tripay_private_key
TRIPAY_MERCHANT_CODE=your_tripay_merchant_code
TRIPAY_BASE_URL=https://tripay.co.id/api

# ==============================================
# Duitku
# ==============================================
DUITKU_API_KEY=your_duitku_api_key
DUITKU_MERCHANT_CODE=your_duitku_merchant_code
DUITKU_BASE_URL=https://api-prod.duitku.com/api

# ==============================================
# Paydisini
# ==============================================
PAYDISINI_API_KEY=your_paydisini_api_key
PAYDISINI_BASE_URL=https://paydisini.co.id/api
