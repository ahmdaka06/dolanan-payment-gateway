# App
APP_PORT=3001
APP_PREFIX=api/v1
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=dolanan
DB_PASSWORD=dolanan_secret
DB_DATABASE=dolanan_payment_gateway

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting (Throttle)
THROTTLE_TTL=60000 # miliseconds (default 60 seconds)
THROTTLE_LIMIT=100 # default 100 requests

# JWT
JWT_SECRET=super-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Tripay
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_BASE_URL=https://tripay.co.id/api

# Duitku
DUITKU_API_KEY=
DUITKU_MERCHANT_CODE=
DUITKU_BASE_URL=https://api-prod.duitku.com/api

# Paydisini
PAYDISINI_API_KEY=
PAYDISINI_BASE_URL=https://paydisini.co.id/api
